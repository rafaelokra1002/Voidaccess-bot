{
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://voidaccess-bot.onrender.com/api/:path*" },
    { "source": "/health", "destination": "https://voidaccess-bot.onrender.com/health" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
